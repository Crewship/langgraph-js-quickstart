OPENAI_API_KEY=your-openai-api-key-here

# Using a different provider? Swap ChatOpenAI in src/graph.ts and set the matching key:
# ANTHROPIC_API_KEY=...   → import { ChatAnthropic } from "@langchain/anthropic"   model: "claude-3-5-haiku-20241022"
# GROQ_API_KEY=...        → import { ChatGroq } from "@langchain/groq"             model: "llama-3.3-70b-versatile"  (free tier)
